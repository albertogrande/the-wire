---
import LabLayout from '../../layouts/LabLayout.astro';
import { withBase } from '../../lib/wire';
const labs = [
  { id: 'a', name: 'A · Monospace Grid', desc: 'The Monospace Web + Vercel — one mono typeface, rules not boxes, lots of air.' },
  { id: 'b', name: 'B · Newswire', desc: 'Businessweek editorial — bold serif hero, newspaper hierarchy, one hot accent.' },
  { id: 'c', name: 'C · Modern Cards', desc: 'Supabase-light + Vercel — clean surface, soft rounded cards, green accent.' },
];
---
<LabLayout title="Design lab">
  <div class="lab-pick">
    <h1>The Wire — design lab</h1>
    <p>Mobile-first, light, lead-forward. The front = The Week + latest dives; everything else is a tap away.</p>
    {labs.map((l) => (
      <a href={withBase(`/lab/${l.id}`)}><b>{l.name}</b><span>{l.desc}</span></a>
    ))}
    <a href={withBase('/')}><b>← back to live front</b></a>
  </div>
</LabLayout>
