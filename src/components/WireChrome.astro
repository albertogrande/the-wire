---
// Terminal chrome (mono-grid design). A `$ the wire` mark with a blinking
// cursor, `--flag` nav, and a slim command-line context row that doubles as a
// breadcrumb. Width follows the page: 760 for the front, --wrap for reading.
import { withBase } from '../lib/wire';

interface Props {
  wide?: boolean;
}
const { wide = false } = Astro.props;
const max = wide ? '760px' : 'var(--wrap)';

const nav = [
  { label: 'feed', url: '/feed' },
  { label: 'predictions', url: '/predictions/' },
  { label: 'threads', url: '/threads/' },
  { label: 'about', url: '/about/' },
];
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (url: string) => (withBase(url).replace(/\/$/, '') || '/') === here;

const seg = here === (withBase('/').replace(/\/$/, '') || '/') ? '' : here.split('/').filter(Boolean).pop() ?? '';
const cmd =
  here === (withBase('/').replace(/\/$/, '') || '/')
    ? 'wire read --latest'
    : here.includes('/predictions')
      ? 'wire score --ledger'
      : here.includes('/threads')
        ? 'wire threads --open'
        : here.includes('/feed')
          ? 'wire feed --live'
          : here.includes('/about')
            ? 'wire --about'
            : here.includes('/reports')
              ? `less ${seg}`
              : 'wire';
---
<div class="chrome" style={`max-width:${max}`}>
  <header class="chrome-head">
    <a href={withBase('/')} class="chrome-mark">
      <span class="amber">$</span> the&nbsp;wire<span class="cur" aria-hidden="true">▌</span>
    </a>
    <nav class="chrome-nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={withBase(n.url)} class={isCurrent(n.url) ? 'is-here' : ''} aria-current={isCurrent(n.url) ? 'page' : undefined}>--{n.label}</a>
      ))}
      <button id="theme-toggle" class="chrome-toggle" type="button" aria-label="Toggle light or dark theme" aria-pressed="false">◐</button>
    </nav>
  </header>
  <div class="chrome-cmd"><span class="dim">~/the-wire</span> <span class="amber">$</span> {cmd}<span class="cur" aria-hidden="true">▌</span></div>
</div>
