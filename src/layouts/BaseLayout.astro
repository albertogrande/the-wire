---
import '../styles/main.scss';
import Head from '../components/Head.astro';
import WireChrome from '../components/WireChrome.astro';
import Footer from '../components/Footer.astro';
import Shortcuts from '../components/Shortcuts.astro';

interface Props {
  title: string;
  description?: string;
  home?: boolean; // Front page: wide chrome + full-bleed body (island supplies its own layout)
}
const { title, description, home = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <Head title={title} description={description} />
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <WireChrome wide={home} />
    {
      home ? (
        <main id="main"><slot /></main>
      ) : (
        <main class="page" id="main"><slot /></main>
      )
    }
    <Footer />
    <Shortcuts />
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var root = document.documentElement;
        function sync() {
          var dark = root.getAttribute('data-theme') === 'dark';
          btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
        }
        sync();
        btn.addEventListener('click', function () {
          var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try {
            localStorage.setItem('obs-theme', next);
          } catch (e) {}
          sync();
        });
      })();
    </script>
  </body>
</html>
